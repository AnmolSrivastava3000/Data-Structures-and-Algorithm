	sol(matrix,k);}

public static void sol(int mat[][],int k){
	int m=mat.length-1;
	int n=mat[0].length-1;
	int row=0;
	while(row<=m){
	int mid = row+ (m-row)/2;
	if(k>= mat[mid][0] && k<= mat[mid][n]){
	// sol exist in this row
	helper(mat,k,mid);
	return;}

		else if(k< mat[mid][0]) {
		m=mid-1;}
	else row = mid+1;
}}

public static void helper(int mat[][],int k,int mid){
	int n=mat[0].length-1;
	int col=0;
	while(col<=n){
	int colmid=col+(n-col)/2;
	if(mat[mid][colmid]==k){
	// sol exist 
	System.out.print("found the sol");
	return;}

		else if(k <mat[mid][colmid]) {
		n=colmid-1;}
	else col = colmid+1;
}
}

