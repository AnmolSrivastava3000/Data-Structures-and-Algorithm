class Solution {
    public boolean isPalindrome(String s) {
        int n =s.length()-1;
        int left=0;
        while(left<n){
            if(!Character.isLetterOrDigit(s.charAt(left))){
                left++;
            }
            else if(!Character.isLetterOrDigit(s.charAt(n))){
                n--;
            }
            else if(Character.toLowerCase(s.charAt(left))==Character.toLowerCase(s.charAt(n))){
                left++;n--;
            }
            else{return false;}
        }
        return true;
    }
}
