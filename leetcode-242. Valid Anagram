class Solution {
    public boolean isAnagram(String s, String t) {
    int n=s.length();
    int m =t.length();
    if(n!=m) return false;

    int val=0;
    int arr[] =new int[26];
    // int arr1[]=new int[26];
    for(int i=0;i<n;i++){
        val=Character.toLowerCase(s.charAt(i))-97;
        arr[val]++;
        val=Character.toLowerCase(t.charAt(i))-97;
        arr[val]--;
    }
    
    for(int i=0;i<26;i++){
        if(arr[i]!=0) return false;
    }
    return true;
    }
}
